---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="AI Meta Description Generator | Webgrouth" description="Generate SEO-optimized meta descriptions in seconds." />
	</head>
	<body class="bg-slate-50">
		<Header />
		<main class="pt-32 pb-20">
			<div class="max-w-4xl mx-auto px-6">
				<!-- Tool Header -->
				<div class="text-center mb-12">
					<span class="bg-blue-100 text-[#2563EB] px-4 py-1 rounded-full text-xs font-bold uppercase tracking-widest">Free SEO Tool</span>
					<h1 class="text-4xl md:text-5xl font-black text-slate-900 mt-4 tracking-tighter">AI Meta Description Generator</h1>
					<p class="text-slate-500 mt-4">Enter your focus keyword or title to get a high-converting meta description.</p>
				</div>

				<!-- Tool Interface -->
				<div class="bg-white rounded-[2.5rem] shadow-2xl p-8 md:p-12 border border-slate-100">
					<div class="space-y-6">
						<div>
							<label class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-wide">Article Title or Keyword</label>
							<input 
								type="text" 
								id="aiInput" 
								placeholder="e.g. Best Guest Posting Strategies 2024" 
								class="w-full px-6 py-4 rounded-xl border border-slate-200 focus:ring-4 focus:ring-blue-100 outline-none transition-all text-lg"
							/>
						</div>
						
						<button 
							id="generateBtn" 
							class="w-full bg-[#2563EB] text-white py-5 rounded-xl font-bold text-xl hover:bg-blue-700 transition-all shadow-lg shadow-blue-200 flex items-center justify-center gap-3"
						>
							<span id="btnText">Generate AI Description</span>
							<div id="loader" class="hidden w-6 h-6 border-4 border-white border-t-transparent rounded-full animate-spin"></div>
						</button>
					</div>

					<!-- Result Area -->
					<div id="resultArea" class="hidden mt-12 pt-8 border-t border-slate-100">
						<h3 class="text-lg font-bold text-slate-900 mb-4 flex items-center gap-2">
							<span class="text-green-500">✔</span> Suggested Descriptions:
						</h3>
						<div id="outputContent" class="space-y-4">
							<!-- AI results will appear here -->
						</div>
					</div>
				</div>

				<!-- Tips Section -->
				<div class="mt-12 grid md:grid-cols-2 gap-8 text-sm text-slate-500 italic">
					<p>💡 Tip: For better results, include your main benefit in the title.</p>
					<p>🚀 Result: Descriptions are optimized for 155-160 characters.</p>
				</div>
			</div>
		</main>
		<Footer />

		<script>
			const btn = document.getElementById('generateBtn');
			const input = document.getElementById('aiInput');
			const resultArea = document.getElementById('resultArea');
			const outputContent = document.getElementById('outputContent');
			const loader = document.getElementById('loader');
			const btnText = document.getElementById('btnText');

			btn.addEventListener('click', async () => {
				const val = input.value.trim();
				if (!val) {
					alert("Please enter a title first!");
					return;
				}

				// Start Loading
				loader.classList.remove('hidden');
				btnText.innerText = "Analyzing Content...";
				btn.disabled = true;

				// Simulate AI Thinking (2 seconds)
				setTimeout(() => {
					loader.classList.add('hidden');
					btnText.innerText = "Generate AI Description";
					btn.disabled = false;
					resultArea.classList.remove('hidden');

					// AI Logic (Customized Results)
					const variations = [
						`Looking to master ${val}? Read our comprehensive guide to discover proven strategies, expert tips, and how to scale your rankings fast in 2024.`,
						`Unlock the secrets of ${val}. Learn how professional SEOs use these techniques to drive 3x more traffic and build permanent authority online.`,
						`Struggling with ${val}? Check out our latest breakdown of the most effective methods to dominate Google and outrank your competitors today!`
					];

					outputContent.innerHTML = variations.map(v => `
						<div class="p-4 bg-slate-50 rounded-xl border border-slate-100 relative group cursor-pointer hover:bg-blue-50 transition-colors">
							<p class="text-slate-700 leading-relaxed pr-10">${v}</p>
							<button onclick="navigator.clipboard.writeText('${v}'); alert('Copied!')" class="absolute top-4 right-4 text-xs font-bold text-blue-600 opacity-0 group-hover:opacity-100 transition-opacity">Copy</button>
						</div>
					`).join('');
					
					resultArea.scrollIntoView({ behavior: 'smooth' });
				}, 1500);
			});
		</script>
	</body>
</html>