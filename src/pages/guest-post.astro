---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---
<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="SEO Blog | Webgrouth" description="Expert SEO insights" />
	</head>
	<body class="bg-white">
		<Header />
		<main class="pt-32 pb-20">
			<div class="max-w-7xl mx-auto px-6">
				<div class="text-center mb-20">
					<h1 class="text-5xl font-black text-slate-900 tracking-tighter">SEO & AI Insights</h1>
					<p class="text-slate-500 mt-4 text-lg">Stay ahead of the Google algorithm with our expert guides.</p>
				</div>
				<div class="grid md:grid-cols-3 gap-10">
					{[1,2,3].map(i => (
						<article class="group cursor-pointer">
							<div class="overflow-hidden rounded-[2rem] mb-6 shadow-lg">
								<img src={`https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&w=600&q=80`} class="group-hover:scale-110 transition-all duration-500 h-64 w-full object-cover" alt="Blog post"/>
							</div>
							<p class="text-[#2563EB] font-bold text-xs uppercase tracking-widest mb-3">SEO Strategy</p>
							<h3 class="text-2xl font-bold text-slate-900 group-hover:text-[#2563EB] transition-colors mb-4">How AI is changing SEO in 2024</h3>
							<p class="text-slate-500 line-clamp-2 italic text-sm">Learn why human-polished content is still the king of search engine rankings.</p>
						</article>
					))}
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>